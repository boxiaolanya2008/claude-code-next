#!/usr/bin/env bash
set -euo pipefail

# Save original working directory
ORIGINAL_CWD="$(pwd)"

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Convert to Windows paths for bun on Windows
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]]; then
  WIN_ROOT="$(cygpath -w "$ROOT_DIR")"
  PRELOAD_PATH="${WIN_ROOT}\\preload.ts"
  CLI_PATH="${WIN_ROOT}\\src\\entrypoints\\cli.tsx"
  ENV_FILE="${WIN_ROOT}\\.env"
  WIN_CWD="$(cygpath -w "$ORIGINAL_CWD")"
else
  PRELOAD_PATH="$ROOT_DIR/preload.ts"
  CLI_PATH="$ROOT_DIR/src/entrypoints/cli.tsx"
  ENV_FILE="$ROOT_DIR/.env"
fi

# Pass original cwd via environment variable
export CLAUDE_CODE_ORIGINAL_CWD="$ORIGINAL_CWD"

# Change to original directory before executing
cd "$ORIGINAL_CWD"

exec bun --preload="$PRELOAD_PATH" --env-file="$ENV_FILE" "$CLI_PATH" "$@"
